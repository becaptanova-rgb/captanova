# ==============================
# CAPTANOVA ACADEMY - ENV CONFIG
# ==============================

# Resend Email API (https://resend.com)
RESEND_API_KEY=re_PLACEHOLDER_YOUR_RESEND_API_KEY

# From email (must be verified domain in Resend)
RESEND_FROM_EMAIL=hello@captanovaacademy.com
RESEND_FROM_NAME=Captanova Academy

# Google Sheets (App Script Web App URL)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/PLACEHOLDER_YOUR_APPSCRIPT_ID/exec

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_PLACEHOLDER
RAZORPAY_KEY_SECRET=PLACEHOLDER_YOUR_RAZORPAY_SECRET
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_PLACEHOLDER

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=PLACEHOLDER_YOUR_META_PIXEL_ID

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-PLACEHOLDER

# WhatsApp Business Number (with country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=+4571587709

# Site URL
NEXT_PUBLIC_SITE_URL=https://captanovaacademy.com
